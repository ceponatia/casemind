{
    "name": "@casemind/test-utils",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "exports": {
        ".": "./src/index.ts"
    },
    "dependencies": {
        "testcontainers": "^11.12.0"
    },
    "devDependencies": {
        "vitest": "^3.0.8"
    },
    "scripts": {
        "lint": "eslint src tests",
        "typecheck": "tsc -p tsconfig.json",
        "test": "vitest run --config vitest.config.ts --dir tests/unit",
        "test:integration": "vitest run --config vitest.config.ts --dir tests/integration"
    }
}