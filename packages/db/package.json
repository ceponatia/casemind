{
    "name": "@casemind/db",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "exports": {
        ".": "./src/index.ts"
    },
    "dependencies": {
        "@casemind/platform-config": "workspace:*",
        "@prisma/client": "^7.4.2",
        "mongodb": "^7.1.0",
        "pg": "^8.20.0"
    },
    "devDependencies": {
        "@casemind/test-utils": "workspace:*",
        "@types/pg": "^8.18.0",
        "fast-check": "^4.0.1",
        "prisma": "^7.4.2",
        "tsx": "^4.21.0",
        "vitest": "^3.0.8"
    },
    "scripts": {
        "lint": "eslint src tests",
        "typecheck": "tsc -p tsconfig.json",
        "test": "vitest run --config vitest.config.ts tests/unit tests/contract",
        "test:integration": "vitest run --config vitest.config.ts --dir tests/integration",
        "test:mutate": "stryker run stryker.config.mjs",
        "db:migrate:local": "tsx src/scripts/migrate-local.ts",
        "db:indexes:local": "tsx src/scripts/indexes-local.ts",
        "db:seed:local": "tsx src/scripts/seed-local.ts",
        "db:reset:local": "tsx src/scripts/reset-local.ts"
    }
}